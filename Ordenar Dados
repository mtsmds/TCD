#include <stdio.h>
#include <stdlib.h>
#include <time.h>

/* ================= INSERTION SORT ================= */
// Ordena o vetor usando Insertion Sort
// Bom para vetores pequenos ou quase ordenados, simples de implementar
void insertionSort(int v[], int n) {
    int i, j, chave;
    for(i = 1; i < n; i++) {
        chave = v[i]; // Elemento guardado para inserir na posição correta
        j = i - 1;

        // Move elementos maiores uma posição à direita
        while(j >= 0 && v[j] > chave) {
            v[j + 1] = v[j];
            j--;
        }
        v[j + 1] = chave; // Insere o elemento na posição correta
    }
}

/* ================= MERGE SORT ================= */
// Ordena recursivamente dividindo o vetor em metades
void merge(int arr[], int inicio, int meio, int fim) {
    int tamanhoEsq = meio - inicio + 1;
    int tamanhoDir = fim - meio;

    int *esq = (int*) malloc(tamanhoEsq * sizeof(int));
    int *dir = (int*) malloc(tamanhoDir * sizeof(int));

    for (int i = 0; i < tamanhoEsq; i++) esq[i] = arr[inicio + i];
    for (int i = 0; i < tamanhoDir; i++) dir[i] = arr[meio + 1 + i];

    int i = 0, j = 0, k = inicio;
    while (i < tamanhoEsq && j < tamanhoDir) {
        if (esq[i] <= dir[j]) arr[k++] = esq[i++];
        else arr[k++] = dir[j++];
    }
    while (i < tamanhoEsq) arr[k++] = esq[i++];
    while (j < tamanhoDir) arr[k++] = dir[j++];

    free(esq);
    free(dir);
}

void mergeSort(int arr[], int inicio, int fim) {
    if (inicio < fim) {
        int meio = inicio + (fim - inicio) / 2;
        mergeSort(arr, inicio, meio);
        mergeSort(arr, meio + 1, fim);
        merge(arr, inicio, meio, fim);
    }
}

/* ================= QUICK SORT ================= */
void trocar(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

int particionar(int arr[], int inicio, int fim) {
    int pivo = arr[fim]; 
    int i = inicio - 1;

    for (int j = inicio; j < fim; j++) {
        if (arr[j] <= pivo) {
            i++;
            trocar(&arr[i], &arr[j]);
        }
    }
    trocar(&arr[i + 1], &arr[fim]);
    return i + 1;
}

void quickSort(int arr[], int inicio, int fim) {
    if (inicio < fim) {
        int indicePivo = particionar(arr, inicio, fim);
        quickSort(arr, inicio, indicePivo - 1);
        quickSort(arr, indicePivo + 1, fim);
    }
}

/* ================= RADIX SORT ================= */
// Ordena números inteiros usando posição de dígitos (não comparativo)
// Justificativa: escolhido como algoritmo extra para mostrar alternativa
// a ordenação não comparativa, útil para grandes conjuntos de inteiros.
// Diferente dos outros, o Radix pode ser mais rápido que O(n log n) em casos específicos
void radixsort(int vetor[], int n){
    int i, j, k, exp = 1, m;
    int L[100], R[100]; // Listas temporárias para dígitos menores e maiores

    // Encontra o maior número do vetor para determinar número de dígitos
    m = vetor[0];
    for(i = 1; i < n; i++)
        if(vetor[i] > m) m = vetor[i];

    // Processa cada dígito, do menos significativo ao mais significativo
    while(m / exp > 0){
        j = 0; k = 0;
        for(i = 0; i < n; i++){
            if((vetor[i]/exp)%10 < 5) L[j++] = vetor[i]; // números "menores"
            else R[k++] = vetor[i];                       // números "maiores"
        }
        for(i = 0; i < j; i++) vetor[i] = L[i];
        for(i = 0; i < k; i++) vetor[j+i] = R[i];
        exp *= 10; // Avança para o próximo dígito
    }
}

/* ================= BUBBLE SORT ================= */
// Ordena comparando elementos adjacentes, repetidamente
void bubbleSort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - 1 - i; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

/* ================= SELECTION SORT ================= */
// Ordena selecionando o menor elemento e trocando com a posição atual
void selectionSort(int arr[], int n) {
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (arr[j] < arr[minIdx]) minIdx = j;
        }
        int temp = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = temp;
    }
}

/* ================= FUNÇÕES AUXILIARES ================= */
void imprimir(int v[], int n){
    for(int i = 0; i < n; i++) printf("%d ", v[i]);
    printf("\n");
}

void salvarVetor(int v[], int n, const char* filename){
    FILE *f = fopen(filename, "w");
    if(f == NULL){
        printf("Erro ao criar o arquivo.\n");
        return;
    }
    for(int i = 0; i < n; i++) fprintf(f, "%d ", v[i]);
    fprintf(f, "\n");
    fclose(f);
    printf("Vetor salvo em %s\n", filename);
}

/* ================= MAIN ================= */
int main(){
    int vetor[] = {35, 3, 9, 30, 28, 21, 43, 8, 1, 2};
    int n = sizeof(vetor)/sizeof(vetor[0]);
    int opcao;
    clock_t inicio, fim;
    double tempo;

    printf("Escolha o algoritmo de ordenacao:\n");
    printf("1 - Insertion Sort\n");
    printf("2 - Merge Sort\n");
    printf("3 - Quick Sort\n");
    printf("4 - Radix Sort (ilustra escolha de algoritmo extra)\n");
    printf("5 - Bubble Sort\n");
    printf("6 - Selection Sort\n");
    printf("Opcao: ");
    scanf("%d", &opcao);

    inicio = clock();
    switch(opcao){
        case 1: insertionSort(vetor, n); break;
        case 2: mergeSort(vetor, 0, n-1); break;
        case 3: quickSort(vetor, 0, n-1); break;
        case 4: radixsort(vetor, n); break;
        case 5: bubbleSort(vetor, n); break;
        case 6: selectionSort(vetor, n); break;
        default: printf("Opcao invalida\n"); return 0;
    }
    fim = clock();

    tempo = ((double)(fim - inicio)) / CLOCKS_PER_SEC;

    printf("Vetor ordenado:\n");
    imprimir(vetor, n);

    printf("Tempo de execucao: %.6f segundos\n", tempo);

    char filename[50];
    printf("Digite o nome do arquivo para salvar o vetor ordenado (ex: vetor.txt): ");
    scanf("%s", filename);
    salvarVetor(vetor, n, filename);

    return 0;
}
